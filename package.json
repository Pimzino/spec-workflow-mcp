{
  "name": "@pimzino/spec-workflow-mcp",
  "version": "2.2.7",
  "description": "MCP server for spec-driven development workflow with real-time web dashboard",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/dashboard",
    "packages/vscode-extension"
  ],
  "scripts": {
    "build": "npm run build -w packages/shared && npm run build -w packages/server && npm run build -w packages/dashboard",
    "build:shared": "npm run build -w packages/shared",
    "build:server": "npm run build -w packages/server",
    "build:dashboard": "npm run build -w packages/dashboard",
    "dev": "npm run dev -w packages/server",
    "dev:dashboard": "npm run dev -w packages/dashboard",
    "start": "npm run start -w packages/server",
    "clean": "npm run clean -w packages/shared && npm run clean -w packages/server && rimraf packages/dashboard/dist",
    "test": "npm run test -w packages/server",
    "test:watch": "npm run test:watch -w packages/server",
    "test:coverage": "npm run test:coverage -w packages/server",
    "test:e2e": "playwright test",
    "test:e2e:worktree": "playwright test -c playwright.worktree.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:generate-approvals": "node scripts/generate-test-approvals.cjs",
    "validate:i18n": "node scripts/validate-i18n.js",
    "validate:mdx": "tsx scripts/validate-mdx.ts",
    "sync:plugin-version": "node scripts/sync-plugin-version.js",
    "check:plugin-version": "node scripts/sync-plugin-version.js --check",
    "copy-static": "node scripts/copy-static.cjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "spec-workflow",
    "ai-development",
    "claude",
    "cursor",
    "development-workflow",
    "project-management"
  ],
  "author": "",
  "license": "GPL-3.0",
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.7.2"
  }
}
